SECRET_KEY=troque-por-uma-chave-segura

# NOVO: login trocado de e-mail para usuário (ADMIN_EMAIL/VIEWER_EMAIL viraram
# ADMIN_USERNAME/VIEWER_USERNAME). Os valores abaixo são só para teste local —
# troque antes de usar fora do seu computador.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
VIEWER_USERNAME=tv
VIEWER_PASSWORD=tv12345678

# NOVO (pacote de teste): deixado comentado de propósito. Sem essa variável o
# app usa SQLite local (linkaggreg/links.db) automaticamente, o que é o mais
# simples para testar. Descomente e ajuste só quando for rodar com PostgreSQL.
# DATABASE_URL=postgresql://usuario:senha@host:5432/agregador_links

# NOVO: liga/desliga o modo debug do Flask. Deixe "false" (ou remova) em produção —
# debug=true expõe o console interativo do Werkzeug, que permite executar código
# arbitrário no servidor a quem acessar a página de erro.
# IMPORTANTE: com FLASK_DEBUG=false, a SECRET_KEY acima passa a ser obrigatória —
# o app não sobe sem ela (ver app.py). Deixe "true" só para testes locais rápidos.
FLASK_DEBUG=false

# NOVO: marque como "true" somente quando o site rodar atrás de HTTPS.
# Isso instrui o navegador a só enviar o cookie de sessão em conexões seguras.
COOKIE_SECURE=false

# Porta em que o servidor escuta, tanto via `python app.py` quanto via
# `python serve.py` (Waitress).
PORT=5001

# NOVO: endereço em que o servidor escuta.
# 127.0.0.1 (padrão) = só este computador acessa. Use assim com "python app.py".
# 0.0.0.0 = qualquer dispositivo da rede local acessa pelo IP deste computador
# (ex.: http://192.168.1.50:5001). Para rodar assim de verdade, prefira
# "python serve.py" em vez de "python app.py" — ver PLANO-REDE.md.
HOST=127.0.0.1

# NOVO: quantidade máxima de links simultâneos no painel (antes fixo em 8 no código).
MAX_LINKS=8

# NOVO: onde o Flask-Limiter guarda a contagem de tentativas de login.
# "memory://" (padrão) é suficiente para um único processo. Se rodar com vários
# workers/instâncias, aponte para um Redis compartilhado, ex.: redis://localhost:6379.
RATELIMIT_STORAGE_URI=memory://
