SECRET_KEY=troque-por-uma-chave-segura
DATABASE_URL=postgresql://usuario:senha@host:5432/agregador_links
ADMIN_EMAIL=admin@fieg.com.br
ADMIN_PASSWORD=troque-a-senha-admin
VIEWER_EMAIL=tv@fieg.com.br
VIEWER_PASSWORD=troque-a-senha-tv

# NOVO: liga/desliga o modo debug do Flask. Deixe "false" (ou remova) em produção —
# debug=true expõe o console interativo do Werkzeug, que permite executar código
# arbitrário no servidor a quem acessar a página de erro.
FLASK_DEBUG=false

# NOVO: marque como "true" somente quando o site rodar atrás de HTTPS.
# Isso instrui o navegador a só enviar o cookie de sessão em conexões seguras.
COOKIE_SECURE=false

# Porta em que o servidor Flask escuta quando executado via `python app.py`.
PORT=5001
